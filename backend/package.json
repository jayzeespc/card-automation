{
  "name": "card-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:qa": "set APP_ENV=qa&& set NODE_ENV=production&& set ENV_FILE=.env.qa&& node server.js",
    "start:prod": "set APP_ENV=prod&& set NODE_ENV=production&& set ENV_FILE=.env.prod&& node server.js",
    "regression:batch": "node scripts/runRegressionBatch.mjs",
    "regression:beta": "node scripts/runRegressionBatch.mjs \"D:/Sport Cards/Scanned from Epson/Football\" --limit=20 --gate=beta",
    "regression:beta:ci": "node scripts/runRegressionBatch.mjs \"D:/Sport Cards/Scanned from Epson/Football\" --limit=20 --gate=beta --fail-on-gate"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2",
    "sqlite3": "^6.0.1",
    "xlsx": "^0.18.5"
  }
}
