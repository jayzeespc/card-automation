# CardPilot HQ - QA environment example
APP_NAME=CardPilot HQ
APP_ENV=qa
PORT=3000

# Optional: lock browser origins for QA. Comma-separated list.
# Example when testing from same PC and phone on home LAN:
# CORS_ORIGIN=http://localhost:3000,http://192.168.1.25:3000
CORS_ORIGIN=

AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_API_KEY=replace-with-qa-key
AZURE_MODEL_ID=prebuilt-read
AZURE_API_VERSION=2024-11-30
USE_MOCK_AI=false

# QA access token (recommended before external testers)
BETA_ACCESS_TOKEN=

# Reliability-first defaults
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
AZURE_DAILY_LIMIT=500
AZURE_RETRY_ATTEMPTS=3
AZURE_SUBMIT_RETRY_ATTEMPTS=4
